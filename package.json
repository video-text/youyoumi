    "@keystatic/core": "0.5.51",
    "astro": "7.0.9",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@types/node": "^24.10.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "wrangler": "4.110.0"
  }
