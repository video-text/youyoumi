---
import site from "../content/site.json";

const pageTitle = "店铺数据看板 | " + site.brandName;
const pageDescription = "二店 MIOU 与三店 QUEJO 的原始数据与经营分析可视化。";
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content={pageDescription}>
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="#071a2b">
    <link rel="canonical" href="https://youyoumi.asia/tiktok-shops/">
    <title>{pageTitle}</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/tiktok-shops.css">
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
    <script is:inline src="/script.js" defer></script>
    <script is:inline src="/tiktok-shops.js" defer></script>
  </head>
  <body class="shops-page">
    <a class="skip-link" href="#content">跳到内容</a>

    <header class="site-header" id="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="/" aria-label="Vielumi Global 首页">
          <span class="brand-mark" aria-hidden="true">V</span>
          <span>{site.brandName}</span>
        </a>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation">
          <span class="sr-only">打开导航</span>
          <span></span><span></span><span></span>
        </button>
        <nav class="primary-nav" id="primary-navigation" aria-label="主导航">
          <a href="/">Home</a>
          <a href="/product-analysis/">Product Intelligence</a>
          <a class="active" href="/tiktok-shops/" aria-current="page">Shop Dashboard</a>
          <a href="/#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="content">
      <section class="shops-hero">
        <div class="container">
          <p class="eyebrow">TikTok Shop · Brazil Local</p>
          <h1>二店 / 三店经营看板</h1>
          <p class="lead">原始订单与商品数据，加上销量、库存、状态分布等分析图表。数据来自店铺实时 Open API 快照。</p>
          <p class="meta" id="updated-at">加载中…</p>
        </div>
      </section>

      <section class="container">
        <div class="shop-tabs" role="tablist" aria-label="店铺切换">
          <button class="shop-tab active" type="button" data-shop="0">三店 QUEJO</button>
          <button class="shop-tab" type="button" data-shop="1">二店 MIOU</button>
          <button class="shop-tab" type="button" data-shop="compare">双店对比</button>
        </div>
      </section>

      <section class="container kpi-grid" id="kpi-grid" aria-live="polite"></section>

      <section class="container view-panels">
        <div class="panel-tabs" role="tablist">
          <button class="panel-tab active" type="button" data-panel="charts">分析图表</button>
          <button class="panel-tab" type="button" data-panel="raw">原始数据</button>
        </div>

        <div id="panel-charts" class="panel-body active">
          <div class="chart-grid" id="chart-grid">
            <article class="chart-card"><h3>日 GMV / 订单</h3><canvas id="chart-daily"></canvas></article>
            <article class="chart-card"><h3>订单状态分布</h3><canvas id="chart-order-status"></canvas></article>
            <article class="chart-card"><h3>商品状态分布</h3><canvas id="chart-product-status"></canvas></article>
            <article class="chart-card"><h3>库存区间分布</h3><canvas id="chart-inventory"></canvas></article>
            <article class="chart-card chart-wide"><h3>销量 Top 商品</h3><canvas id="chart-top-products"></canvas></article>
            <article class="chart-card chart-wide" id="compare-charts" hidden>
              <h3>双店对比</h3>
              <canvas id="chart-compare"></canvas>
            </article>
          </div>
        </div>

        <div id="panel-raw" class="panel-body">
          <div class="raw-toolbar">
            <label>数据表
              <select id="raw-table-select">
                <option value="products">商品原始数据</option>
                <option value="orders">订单原始数据</option>
              </select>
            </label>
            <input id="raw-search" type="search" placeholder="搜索标题 / SKU / 订单号…" />
            <span class="meta" id="raw-count"></span>
          </div>
          <div class="table-wrap">
            <table id="raw-table">
              <thead id="raw-thead"></thead>
              <tbody id="raw-tbody"></tbody>
            </table>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} {site.brandName}. Shop operations dashboard.</p>
      </div>
    </footer>
  </body>
</html>
