  "endpoints": [
    {
      "group": "授权 / 店铺",
      "items": [
        { "method": "GET", "path": "/authorization/202309/shops", "desc": "已授权店铺列表", "scope": "seller.authorization.info" },
        { "method": "GET", "path": "/seller/202309/shops", "desc": "卖家店铺信息", "scope": "seller.shop.info" }
      ]
    },
    {
      "group": "商品",
      "items": [
        { "method": "POST", "path": "/product/202309/products/search", "desc": "搜索商品列表（page_size/page_token 放 query）", "scope": "seller.product.basic" },
        { "method": "GET", "path": "/product/202309/products/{id}", "desc": "商品详情", "scope": "seller.product.basic" },
        { "method": "POST", "path": "/product/202309/products", "desc": "创建本地商品", "scope": "seller.product.write" },
        { "method": "POST", "path": "/product/202309/products/activate", "desc": "激活商品", "scope": "seller.product.write" },
        { "method": "POST", "path": "/product/202309/images/upload", "desc": "上传商品图片（multipart data）", "scope": "seller.product.write" },
        { "method": "POST", "path": "/product/202309/categories/recommend", "desc": "推荐类目", "scope": "seller.product.basic" },
        { "method": "GET", "path": "/product/202309/categories/{id}/attributes", "desc": "类目属性", "scope": "seller.product.basic" },
        { "method": "GET", "path": "/product/202309/categories/{id}/rules", "desc": "类目规则", "scope": "seller.product.basic" }
      ]
    },
    {
      "group": "订单 / 物流 / 履约",
      "items": [
        { "method": "POST", "path": "/order/202309/orders/search", "desc": "搜索订单", "scope": "seller.order.info" },
        { "method": "GET", "path": "/logistics/202309/warehouses", "desc": "仓库列表（发品用 SALES_WAREHOUSE）", "scope": "seller.logistics" },
        { "method": "—", "path": "fulfillment / package / delivery", "desc": "履约、包裹、配送状态相关接口", "scope": "seller.fulfillment.* / delivery.status.write" },
        { "method": "—", "path": "return_refund", "desc": "退货退款基础接口", "scope": "seller.return_refund.basic" }
      ]
    },
    {
      "group": "营销 / 财务 / 达人 / 数据",
      "items": [
        { "method": "—", "path": "promotion", "desc": "促销活动读/写", "scope": "seller.promotion.info / write" },
        { "method": "—", "path": "finance", "desc": "财务信息", "scope": "seller.finance.info" },
        { "method": "—", "path": "affiliate / creator marketplace", "desc": "联盟协作、达人市场、私信", "scope": "seller.affiliate_* / creator_marketplace" },
        { "method": "—", "path": "analytics / bestselling", "desc": "店铺分析与畅销数据（路径需按官方文档确认）", "scope": "data.shop_analytics / bestselling" }
      ]
    }
  ],
  "cli": [
    "python scripts/tiktok_shop_auth.py shops",
    "python scripts/tiktok_shop_auth.py --profile shop2 shops",
    "python scripts/tiktok_shop_upload_from_excel.py --excel \"路径.xlsx\" --execute",
    "python scripts/tiktok_shop_dashboard.py --port 8088"
  ]
